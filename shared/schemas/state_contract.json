{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ROCmNavigatorStateContract",
  "type": "object",
  "required": [
    "session_id",
    "status",
    "confidence"
  ],
  "properties": {
    "session_id": {
      "type": "string",
      "format": "uuid"
    },
    "project_owner": {
      "type": "string",
      "default": "Ansh"
    },
    "status": {
      "type": "string",
      "enum": [
        "INITIALIZED",
        "SCANNING",
        "ANALYZING",
        "REWRITING",
        "SECURING",
        "VALIDATING",
        "BENCHMARKING",
        "COMPLETED",
        "FAILED"
      ]
    },
    "confidence": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0,
      "default": 1.0
    },
    "repository": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "size_bytes": { "type": "integer" },
        "file_count": { "type": "integer" },
        "cuda_file_count": { "type": "integer" }
      }
    },
    "scanner": {
      "type": "object",
      "properties": {
        "files": {
          "type": "array",
          "items": { "type": "string" }
        },
        "cuda_kernels": {
          "type": "array",
          "items": { "type": "object" }
        },
        "memory_apis": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "architecture": {
      "type": "object",
      "properties": {
        "dependency_graph": { "type": "object" },
        "deadlocks_detected": { "type": "boolean" },
        "difficulty_score": { "type": "integer" },
        "health_score": { "type": "integer" }
      }
    },
    "knowledge": {
      "type": "object",
      "properties": {
        "rag_queries": { "type": "array", "items": { "type": "string" } },
        "resolved_mappings": { "type": "object" }
      }
    },
    "rewrite": {
      "type": "object",
      "properties": {
        "current_hip_candidate": { "type": "string" },
        "original_code_size": { "type": "integer" },
        "rewritten_code_size": { "type": "integer" }
      }
    },
    "security": {
      "type": "object",
      "properties": {
        "security_clearance_status": { "type": "boolean" },
        "vulnerabilities": { "type": "array", "items": { "type": "object" } },
        "secrets_detected": { "type": "array", "items": { "type": "string" } }
      }
    },
    "validation": {
      "type": "object",
      "properties": {
        "compilation_success": { "type": "boolean" },
        "compilation_error_logs": { "type": "string" },
        "runtime_success": { "type": "boolean" }
      }
    },
    "performance": {
      "type": "object",
      "properties": {
        "performance_metrics": { "type": "object" },
        "efficiency_score": { "type": "number" },
        "execution_time_seconds": { "type": "number" }
      }
    },
    "report": {
      "type": "object",
      "properties": {
        "markdown_report_path": { "type": "string" },
        "pdf_report_path": { "type": "string" }
      }
    }
  }
}
